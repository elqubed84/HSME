<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HSEM.ViewModels"
             x:Class="HSEM.Views.MyMessages"
             Title="الرسائل"
              xmlns:model="clr-namespace:HSEM.Models"
              xmlns:local="clr-namespace:HSEM.Converters"
             NavigationPage.HasBackButton="False"
             BackgroundColor="#F8F8F8">
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:IntToBoolConverter x:Key="IntToBoolConverter"/>
            <local:ReadToFontAttributesConverter x:Key="ReadToFontAttributesConverter" />
            <local:SentAtToAmPmConverter x:Key="SentAtToAmPmConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>
    <ContentPage.BindingContext>
        <vm:MyMessagesViewModel />
    </ContentPage.BindingContext>
    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ToolbarItem_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.Arrow_forward}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem x:Name="menuu" Clicked="ToolbarItem_Clicked_1">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.More_vert}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid BackgroundColor="#F8F8F8" Padding="16">
            <Label Text="الرسائل" FontSize="20" FontAttributes="Bold" TextColor="#1976D2" HorizontalOptions="Center"/>
            <Frame BackgroundColor="Red"
                   CornerRadius="15"
                   Padding="4"
                   HorizontalOptions="End"
                   IsVisible="{Binding UnreadCount, Converter={StaticResource IntToBoolConverter}}">
                <Label Text="{Binding UnreadCount}" TextColor="White" FontSize="12"/>
            </Frame>
        </Grid>

        <!-- Messages List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Messages}"
                        SelectionMode="Single"
                        SelectionChanged="OnMessageSelected"
                        Margin="8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
            StrokeThickness="0"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 12"
            Padding="12"
            Margin="0,0,0,10">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenMessageCommand}"
                    CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="6">

                            <!-- Sender -->
                            <Label Text="{Binding OtherParty.FullName}"
                       FontAttributes="{Binding IsRead, Converter={StaticResource ReadToFontAttributesConverter}}"
                       TextColor="#1976D2"/>

                            <!-- Subject -->
                            <Label Text="{Binding Subject}"
                       FontSize="16"
                       FontAttributes="{Binding IsRead, Converter={StaticResource ReadToFontAttributesConverter}}"
                       TextColor="Black"/>

                            <!-- Date & Time -->
                            <Label Text="{Binding SentAt, Converter={StaticResource SentAtToAmPmConverter}}"
                       FontSize="14"
                       TextColor="Gray"/>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>