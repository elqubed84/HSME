<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
    xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:popup="clr-namespace:Syncfusion.Maui.Popup;assembly=Syncfusion.Maui.Popup"
    xmlns:model="clr-namespace:HSEM.Models"
    xmlns:vm="clr-namespace:HSEM.ViewModels"
    NavigationPage.HasBackButton="False"
    
    x:Class="HSEM.Views.Dashboard"
    Title="لوحة التحكم"
    BackgroundColor="#F2F4F8">

    <ContentPage.BindingContext>
        <vm:DashboardViewModel/>
    </ContentPage.BindingContext>

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="menuu" Clicked="ToolbarItem_Clicked_1">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.More_vert}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid>
        <ScrollView>
            <Grid RowSpacing="12" Padding="14,10,14,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- 0: welcome row -->
                    <RowDefinition Height="Auto" />
                    <!-- 1: profile card -->
                    <RowDefinition Height="Auto" />
                    <!-- 2: divider -->
                    <RowDefinition Height="Auto" />
                    <!-- 3: ✅ BRANCH INFO CARD (جديد) -->
                    <RowDefinition Height="Auto" />
                    <!-- 4: ✅ WARNING FRAME (جديد) -->
                    <RowDefinition Height="Auto" />
                    <!-- 5: divider -->
                    <RowDefinition Height="Auto" />
                    <!-- 6: attendance buttons -->
                    <RowDefinition Height="Auto" />
                    <!-- 7: divider -->
                    <RowDefinition Height="Auto" />
                    <!-- 8: quick actions title -->
                    <RowDefinition Height="Auto" />
                    <!-- 9: quick actions grid -->
                    <RowDefinition Height="Auto" />
                    <!-- 10: divider -->
                    <RowDefinition Height="Auto" />
                    <!-- 11: leave balance title -->
                    <RowDefinition Height="Auto" />
                    <!-- 12: leave balance cards -->
                    <RowDefinition Height="Auto" />
                    <!-- 13: divider -->
                    <RowDefinition Height="Auto" />
                    <!-- 14: latest requests title -->
                    <RowDefinition Height="Auto" />
                    <!-- 15: latest requests list -->
                    <RowDefinition Height="Auto" />
                    <!-- 16: chart divider -->
                </Grid.RowDefinitions>

                <!-- ===== 0: رسالة الترحيب والكود ===== -->
                <Grid Grid.Row="0" ColumnSpacing="10" Margin="2,4,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0"
                           Text="{Binding FullName, StringFormat='أهلاً بيك يا {0} 👋'}"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="Black"
                           HorizontalOptions="Start"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="{Binding EmployeeCode, StringFormat='كود: {0}'}"
                           FontSize="12"
                           TextColor="#666666"
                           HorizontalOptions="End"
                           VerticalOptions="Center"/>
                </Grid>

                <!-- ===== 1: بطاقة الموظف المختصرة ===== -->
                <Border Grid.Row="1"
                        Padding="14"
                        Background="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.08"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <!-- الأفاتار -->
                        <Border Grid.Column="1"
                                WidthRequest="100"
                                HeightRequest="100"
                                BackgroundColor="#164ca0"
                                StrokeShape="RoundRectangle 12"
                                Stroke="OrangeRed"
                                StrokeThickness="2"
                                HorizontalOptions="End"
                                VerticalOptions="Center">
                            <Image Source="{Binding Picture}" Aspect="AspectFill" />
                        </Border>
                        <!-- معلومات موجزة -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                            <Label Text="{Binding FullName}"
                                   FontAttributes="Bold"
                                   FontSize="15"
                                   TextColor="Black"/>
                            <Label Text="{Binding JobTitle}"
                                   FontSize="13"
                                   TextColor="#555555"/>
                            <Label Text="{Binding Department}"
                                   FontSize="12"
                                   TextColor="#164ca0"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ===== 2: فاصل ===== -->
                <BoxView Grid.Row="2" HeightRequest="1" Color="#DDDDDD"/>

                <!-- ===== 3: ✅ بطاقة معلومات الفرع (جديد) ===== -->
                <Border Grid.Row="3"
                        x:Name="BranchInfoFrame"
                        Padding="14"
                        Background="#E3F2FD"
                        Stroke="#1976D2"
                        StrokeThickness="1"
                        IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📍 فرعك"
                               FontAttributes="Bold"
                               FontSize="12"
                               TextColor="#0D47A1"
                               HorizontalOptions="Center"/>
                        <Label x:Name="BranchLabel"
                               Text="جاري التحميل..."
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#1976D2"
                               HorizontalOptions="Center"/>
                        <!-- تفاصيل إضافية (اختياري) -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label x:Name="RequireGpsLabel"
                                       Text="📡 GPS: مطلوب"
                                       FontSize="11"
                                       TextColor="#555555"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label x:Name="RequireWifiLabel"
                                       Text="📶 WiFi: مطلوب"
                                       FontSize="11"
                                       TextColor="#555555"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ===== 4: ✅ رسالة تحذير (موظف بدون فرع) ===== -->
                <Border Grid.Row="4"
                        x:Name="WarningFrame"
                        Padding="16"
                        Background="#FFF3E0"
                        Stroke="#F57C00"
                        StrokeThickness="2"
                        IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="⚠️ تنبيه مهم"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#E65100"
                               HorizontalOptions="Center"/>
                        <Label x:Name="WarningLabel"
                               Text="لم يتم تحديد فرع لك"
                               FontSize="13"
                               TextColor="#E65100"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="برجاء التواصل مع قسم الموارد البشرية لتفعيل خاصية الحضور والانصراف"
                               FontSize="12"
                               TextColor="#BF360C"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="0,4,0,0"/>
                        <!-- زر اتصال (اختياري) -->
                        <buttons:SfButton
                            Text="📞 اتصل بالإدارة"
                            TextColor="White"
                            Background="#F57C00"
                            CornerRadius="8"
                            HeightRequest="36"
                            FontSize="12"
                            Margin="10,4,10,0"
                            HorizontalOptions="Center"
                            WidthRequest="160"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ===== 5: فاصل ===== -->
                <BoxView Grid.Row="5" HeightRequest="1" Color="#DDDDDD"/>

                <!-- ===== 6: أزرار الحضور والانصراف ===== -->
                <Grid Grid.Row="6" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <buttons:SfButton
                        Grid.Column="0"
                        Text="تسجيل حضور"
                        x:Name="AttendanceButton"
                        Clicked="OnAttendanceClicked"
                        TextColor="White"
                        Background="#164ca0"
                        CornerRadius="12"
                        HeightRequest="48"
                        FontAttributes="Bold"
                        FontSize="14"
                        IsVisible="True"/>
                    <buttons:SfButton
                        Grid.Column="1"
                        Text="تسجيل انصراف"
                        x:Name="AttendanceExitButton"
                        Clicked="OnAttendanceExitClicked"
                        TextColor="#164ca0"
                        Background="White"
                        CornerRadius="12"
                        HeightRequest="48"
                        FontAttributes="Bold"
                        FontSize="14"
                        IsVisible="True"/>
                </Grid>

                <!-- ===== 7: فاصل ===== -->
                <BoxView Grid.Row="7" HeightRequest="1" Color="#DDDDDD"/>

                <!-- ===== 8: عنوان الإجراءات السريعة ===== -->
                <Label Grid.Row="8"
                       Text="الإجراءات السريعة"
                       HorizontalOptions="Start"
                       FontAttributes="Bold"
                       FontSize="15"
                       TextColor="#174da1"
                       Margin="2,0,0,0"/>

                <!-- ===== 9: شبكة الإجراءات السريعة ===== -->
                <Grid Grid.Row="9"
                      ColumnDefinitions="*,*,*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="12">

                    <!-- إجازة -->
                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6" HorizontalOptions="Center">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLeaveClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Border BackgroundColor="#E6F1FB" StrokeShape="RoundRectangle 13"
                                Stroke="Transparent" WidthRequest="48" HeightRequest="48"
                                HorizontalOptions="Center">
                            <Image Source="calendar.png" WidthRequest="24"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="إجازة" FontSize="12" FontAttributes="Bold"
                               TextColor="Black" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- حضور / كشف الحضور -->
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6" HorizontalOptions="Center">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMyAttendanceClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Border BackgroundColor="#EAF3DE" StrokeShape="RoundRectangle 13"
                                Stroke="Transparent" WidthRequest="48" HeightRequest="48"
                                HorizontalOptions="Center">
                            <Image Source="biometry.png" WidthRequest="24"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="حضور" FontSize="12" FontAttributes="Bold"
                               TextColor="Black" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- سلفة -->
                    <VerticalStackLayout Grid.Row="0" Grid.Column="2" Spacing="6" HorizontalOptions="Center">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAdvanceClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Border BackgroundColor="#FAEEDA" StrokeShape="RoundRectangle 13"
                                Stroke="Transparent" WidthRequest="48" HeightRequest="48"
                                HorizontalOptions="Center">
                            <Image Source="pay.png" WidthRequest="24"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="سلفة" FontSize="12" FontAttributes="Bold"
                               TextColor="Black" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- تصريح -->
                    <VerticalStackLayout Grid.Row="0" Grid.Column="3" Spacing="6" HorizontalOptions="Center">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPermissionClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Border BackgroundColor="#FAECE7" StrokeShape="RoundRectangle 13"
                                Stroke="Transparent" WidthRequest="48" HeightRequest="48"
                                HorizontalOptions="Center">
                            <Image Source="question.png" WidthRequest="24"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="تصريح" FontSize="12" FontAttributes="Bold"
                               TextColor="Black" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- الراتب -->
                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6" HorizontalOptions="Center">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSalaryClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Border BackgroundColor="#F0EAFA" StrokeShape="RoundRectangle 13"
                                Stroke="Transparent" WidthRequest="48" HeightRequest="48"
                                HorizontalOptions="Center">
                            <Image Source="salary.png" WidthRequest="24"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="الراتب" FontSize="12" FontAttributes="Bold"
                               TextColor="Black" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- تقييمات -->
                    <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6" HorizontalOptions="Center">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEvaluationClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Border BackgroundColor="#E1F5EE" StrokeShape="RoundRectangle 13"
                                Stroke="Transparent" WidthRequest="48" HeightRequest="48"
                                HorizontalOptions="Center">
                            <Image Source="rate.png" WidthRequest="24"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="تقييمات" FontSize="12" FontAttributes="Bold"
                               TextColor="Black" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- رسائل -->
                    <VerticalStackLayout Grid.Row="1" Grid.Column="2" Spacing="6" HorizontalOptions="Center">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMessagesClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Border BackgroundColor="#E6F1FB" StrokeShape="RoundRectangle 13"
                                Stroke="Transparent" WidthRequest="48" HeightRequest="48"
                                HorizontalOptions="Center">
                            <Image Source="messages.png" WidthRequest="24"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="رسائل" FontSize="12" FontAttributes="Bold"
                               TextColor="Black" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- مأمورية -->
                    <VerticalStackLayout Grid.Row="1" Grid.Column="3" Spacing="6" HorizontalOptions="Center">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMissionClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Border BackgroundColor="#EAF3DE" StrokeShape="RoundRectangle 13"
                                Stroke="Transparent" WidthRequest="48" HeightRequest="48"
                                HorizontalOptions="Center">
                            <Image Source="informedconsent.png" WidthRequest="24"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="مأمورية" FontSize="12" FontAttributes="Bold"
                               TextColor="Black" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </Grid>

                <!-- ===== 10: فاصل ===== -->
                <BoxView Grid.Row="10" HeightRequest="1" Color="#DDDDDD"/>

                <!-- ===== 11: عنوان رصيد الإجازات ===== -->
                <Label Grid.Row="11"
                       Text="رصيد الإجازات"
                       HorizontalOptions="Center"
                       FontAttributes="Bold"
                       FontSize="18"
                       TextColor="#333333"/>

                <!-- ===== 12: كروت رصيد الإجازات ===== -->
                <Grid Grid.Row="12"
                      ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="10"
                      RowSpacing="10">

                    <Border Grid.Column="0" Grid.Row="0" Padding="12" Background="#EAF3DE"
                            Stroke="#C0DD97" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="الرصيد الكلي" FontAttributes="Bold" FontSize="12"
                                   TextColor="#3B6D11" HorizontalOptions="Center"/>
                            <Label Text="{Binding LeaveSummary.TotalBalance}" FontAttributes="Bold"
                                   FontSize="26" TextColor="#3B6D11" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="0" Padding="12" Background="#E6F1FB"
                            Stroke="#85B7EB" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="المقبولة" FontAttributes="Bold" FontSize="12"
                                   TextColor="#185FA5" HorizontalOptions="Center"/>
                            <Label Text="{Binding LeaveSummary.Accepted}" FontAttributes="Bold"
                                   FontSize="26" TextColor="#185FA5" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="0" Grid.Row="1" Padding="12" Background="#FAEEDA"
                            Stroke="#FAC775" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="قيد المراجعة" FontAttributes="Bold" FontSize="12"
                                   TextColor="#854F0B" HorizontalOptions="Center"/>
                            <Label Text="{Binding LeaveSummary.Pending}" FontAttributes="Bold"
                                   FontSize="26" TextColor="#854F0B" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="1" Padding="12" Background="#FCEBEB"
                            Stroke="#F7C1C1" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="المرفوضة" FontAttributes="Bold" FontSize="12"
                                   TextColor="#A32D2D" HorizontalOptions="Center"/>
                            <Label Text="{Binding LeaveSummary.Rejected}" FontAttributes="Bold"
                                   FontSize="26" TextColor="#A32D2D" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- ===== 13: فاصل ===== -->
                <BoxView Grid.Row="13" HeightRequest="1" Color="#DDDDDD"/>

                <!-- ===== 14: عنوان آخر الطلبات ===== -->
                <Label Grid.Row="14"
                       Text="آخر طلبات إجازة"
                       HorizontalOptions="Center"
                       FontAttributes="Bold"
                       FontSize="15"
                       TextColor="#333333"/>

                <!-- ===== 15: قائمة الطلبات ===== -->
                <CollectionView Grid.Row="15" ItemsSource="{Binding LatestRequests}">
                    <CollectionView.Header>
                        <Grid ColumnDefinitions="*,*,*" Padding="10,8"
                              BackgroundColor="#ECECEC">
                            <Label Text="التاريخ" FontAttributes="Bold" TextColor="Black" FontSize="13"/>
                            <Label Text="عدد الأيام" Grid.Column="1"
                                   HorizontalTextAlignment="Center"
                                   FontAttributes="Bold" TextColor="Black" FontSize="13"/>
                            <Label Text="الحالة" Grid.Column="2"
                                   HorizontalTextAlignment="End"
                                   FontAttributes="Bold" TextColor="Black" FontSize="13"/>
                        </Grid>
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,*,*" Padding="10,10">
                                <Label Text="{Binding Date}" TextColor="Black" FontSize="13"/>
                                <Label Text="{Binding DaysCount}" Grid.Column="1"
                                       HorizontalTextAlignment="Center" TextColor="Black" FontSize="13"/>
                                <Label Text="{Binding Status}" Grid.Column="2"
                                       HorizontalTextAlignment="End" TextColor="Black" FontSize="13"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ===== 16: عنوان الرسوم البيانية ===== -->
                <BoxView Grid.Row="16" HeightRequest="1" Color="#DDDDDD"/>

            </Grid>
        </ScrollView>

        <!-- ===== Busy Indicator ===== -->
        <core:SfBusyIndicator
            x:Name="lOADER"
            Title="برجاء الإنتظار..."
            FontAttributes="Bold"
            FontSize="25"
            AnimationType="SingleCircle"
            IndicatorColor="#174DA1"
            IsRunning="True"
            IsVisible="{Binding IsLoading}"
            Style="{StaticResource BlueGradientStyle}"
            TextColor="#174DA1"/>
    </Grid>
</ContentPage>