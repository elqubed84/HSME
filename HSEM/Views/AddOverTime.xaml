<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HSEM.Views.AddOverTime"
              xmlns:vm="clr-namespace:HSEM.ViewModels"
 xmlns:vm1="clr-namespace:HSEM.Converters"
  xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
                                                     xmlns:model="clr-namespace:HSEM.Models"
NavigationPage.HasBackButton="False"
BackgroundColor="#F8F8F8"
             Title="طلب يوم تعويضي">
    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ToolbarItem_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.Arrow_forward}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem x:Name="menuu" Clicked="ToolbarItem_Clicked_1">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1"  FontFamily="Icon" Glyph="{x:Static model:IconFont.More_vert}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <ContentPage.BindingContext>
        <vm:CreateCompensatoryDayViewModel />
    </ContentPage.BindingContext>
    <Grid>

        <ScrollView>

            <VerticalStackLayout Spacing="0">

                <!-- صورة علوية -->
                <Image Source="bannart.png"
                   HeightRequest="120"/>

                <!-- العنوان -->
                <Label Text="طلب يوم تعويضي"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="Black"
                   Margin="0,20,0,10"/>

                <!-- الكارت -->
                <Border Margin="20,0,20,20"
                    Padding="20"
                    BackgroundColor="White"
                    Stroke="#2F4F4F"
                    StrokeThickness="1.5">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="16">

                        <!-- تاريخ يوم العمل -->
                        <Label Text="تاريخ يوم العمل"
                           TextColor="Black"
                           FontAttributes="Bold"/>

                        <core:SfTextInputLayout
                        ErrorText="اختر تاريخ يوم العمل"
                        Style="{StaticResource TextInputLayoutStylerr}">
                            <DatePicker Date="{Binding WorkDate}"
                                    TextColor="Black"/>
                        </core:SfTextInputLayout>

                        <!-- وصف العمل -->
                        <Label Text="وصف العمل الذي قمت به"
                           TextColor="Black"
                           FontAttributes="Bold"/>

                        <core:SfTextInputLayout
                        ErrorText="اكتب وصف العمل"
                        Style="{StaticResource TextInputLayoutStylerr}">
                            <Entry Text="{Binding Description}"
                               TextColor="Black"/>
                        </core:SfTextInputLayout>

                        <!-- القيمة الافتراضية -->
                        <Frame BackgroundColor="#F5F5F5"
                           Padding="12"
                           CornerRadius="12"
                           HasShadow="False">

                            <Label TextColor="Black"
                               FontAttributes="Bold"
                               Text="{Binding DefaultRate, StringFormat='القيمة الافتراضية: {0}'}"/>
                        </Frame>

                        <!-- زر الإرسال -->
                        <buttons:SfButton Text="إرسال الطلب"
                                      Command="{Binding SubmitCommand}"
                                      BackgroundColor="#4CAF50"
                                      TextColor="White"
                                      CornerRadius="14"
                                      HeightRequest="48"
                                      Margin="0,10,0,0"/>

                    </VerticalStackLayout>

                </Border>

            </VerticalStackLayout>

        </ScrollView>

        <!-- اللودر -->
        <core:SfBusyIndicator
        Title="جارٍ إرسال الطلب..."
        FontAttributes="Bold"
        AnimationType="SingleCircle"
        IndicatorColor="#174DA1"
        IsRunning="{Binding IsBusy}"
        IsVisible="{Binding IsBusy}"
            Style="{StaticResource BlueGradientStyle}"
        
        TextColor="#174DA1"/>

    </Grid>

</ContentPage>