                                    <Label Text="أيام الغياب:" Grid.Row="1"/>
                                    <Label Text="{Binding Payroll.AbsentDays}" Grid.Row="1" Grid.Column="1"/>

                                    <Label Text="خصم الغياب:" Grid.Row="2"/>
                                    <Label Text="{Binding Payroll.AbsentDeduction, StringFormat='{}{0:N2} EGP'}" Grid.Row="2" Grid.Column="1"/>

                                    <Label Text="الراتب بعد الخصم:" Grid.Row="3"/>
                                    <Label Text="{Binding Payroll.BaseAfterAbsence, StringFormat='{}{0:N2} EGP'}" Grid.Row="3" Grid.Column="1"/>

                                    <Label Text="البدلات:" Grid.Row="4"/>
                                    <Label Text="{Binding Payroll.Allowances, StringFormat='{}{0:N2} EGP'}" Grid.Row="4" Grid.Column="1"/>

                                    <Label Text="بدل إضافي:" Grid.Row="5"/>
