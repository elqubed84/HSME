                                    <Label Text="تأمين الموظف:" Grid.Row="8"/>
                                    <Label Text="{Binding Payroll.InsuranceEmployee, StringFormat='{}{0:N2} EGP'}" Grid.Row="8" Grid.Column="1"/>

                                    <Label Text="تأمين الشركة:" Grid.Row="9"/>
                                    <Label Text="{Binding Payroll.InsuranceCompany, StringFormat='{}{0:N2} EGP'}" Grid.Row="9" Grid.Column="1"/>

                                    <Label Text="ضريبة كسب العمل:" Grid.Row="10"/>
                                    <Label Text="{Binding Payroll.IncomeTax, StringFormat='{}{0:N2} EGP'}" Grid.Row="10" Grid.Column="1"/>

                                    <Label Text="صافي الراتب:" Grid.Row="11"/>
                                    <Label Text="{Binding Payroll.NetSalary, StringFormat='{}{0:N2} EGP'}"
                       Grid.Row="11"
                       Grid.Column="1"
                       TextColor="#2E7D32"
                       FontAttributes="Bold"/>

                                </Grid>
                            </VerticalStackLayout>
                        </ct:Expander.Content>
                    </ct:Expander>
                </Border>-->


            </VerticalStackLayout>
        </ScrollView>

        <!-- اللودر -->
        <!--<core:SfBusyIndicator IsVisible="{Binding IsBusy}"
                              IsRunning="{Binding IsBusy}"
                              Title="جارٍ تحميل البيانات..."
                              BackgroundColor="#88000000"/>-->
    </Grid>
</ContentPage>
