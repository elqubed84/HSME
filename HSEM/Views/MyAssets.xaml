<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HSEM.Views.MyAssets"
             BackgroundColor="#F8F8F8"
              xmlns:model="clr-namespace:HSEM.Models"
 xmlns:vm="clr-namespace:HSEM.ViewModels"
 NavigationPage.HasBackButton="False"
             Title="العهد التى تسلمتها">

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ToolbarItem_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1"  FontFamily="Icon" Glyph="{x:Static model:IconFont.Arrow_forward}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem x:Name="menuu" Clicked="ToolbarItem_Clicked_1">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.More_vert}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <ContentPage.BindingContext>
        <vm:MyAssetsViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid BackgroundColor="#174da1" Padding="15">
            <Label Text="العهدة الخاصة بي"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
        </Grid>

        <!-- Content -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsLoading}">

            <CollectionView ItemsSource="{Binding Assets}"
                            EmptyView="لا توجد عهد مسجلة">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="10"
                               CornerRadius="12"
                               HasShadow="True"
                               Padding="12"
                               BackgroundColor="White">

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="*,Auto">

                                <!-- Asset Name -->
                                <Label Text="{Binding AssetName}"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       TextColor="#333"
                                       Grid.Row="0"
                                       Grid.Column="0"/>

                                <!-- Status -->
                                <Frame Grid.Row="0"
                                       Grid.Column="1"
                                       Padding="5"
                                       CornerRadius="8"
                                       BackgroundColor="#E8F0FE">

                                    <Label Text="{Binding Status}"
                                           FontSize="12"
                                           TextColor="#174da1"/>
                                </Frame>

                                <!-- Serial -->
                                <Label Text="{Binding SerialNumber, StringFormat='Serial: {0}'}"
                                       FontSize="12"
                                       TextColor="#666"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="2"/>

                                <!-- Date -->
                                <Label Text="{Binding AssignedDate, StringFormat='تاريخ التسليم: {0}'}"
                                       FontSize="12"
                                       TextColor="#666"
                                       Grid.Row="2"
                                       Grid.ColumnSpan="2"/>

                                <!-- Description -->
                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       TextColor="#444"
                                       Grid.Row="3"
                                       Grid.ColumnSpan="2"
                                       LineBreakMode="WordWrap"/>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

        <!-- Loading Indicator -->
        <ActivityIndicator IsVisible="{Binding IsLoading}"
                           IsRunning="{Binding IsLoading}"
                           Color="#174da1"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>

    </Grid>

</ContentPage>