<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="HSEM.Views.CompanyPrint"
             xmlns:model="clr-namespace:HSEM.Models"
             NavigationPage.HasBackButton="False"
             BackgroundColor="#F8F8F8"
             Title="إدارة الفروع">

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ToolbarItem_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.Arrow_forward}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem x:Name="menuu" Clicked="ToolbarItem_Clicked_1">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.More_vert}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- صورة علوية -->
                <Image Source="bannart.png"
                       HeightRequest="200"
                       Aspect="AspectFill"/>

                <!-- الكارت الرئيسي -->
                <Border Margin="20"
                        Padding="25"
                        Stroke="#2F4F4F"
                        StrokeThickness="1.5"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="20">

                        <!-- العنوان -->
                        <Label Text="إدارة فروع الشركة"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="Black"/>

                        <!-- زر إضافة فرع جديد -->
                        <buttons:SfButton Text="➕ إضافة فرع جديد"
                                          Clicked="OnAddBranchClicked"
                                          BackgroundColor="#4CAF50"
                                          TextColor="White"
                                          CornerRadius="14"
                                          HeightRequest="50"
                                          FontAttributes="Bold"/>

                        <!-- فاصل -->
                        <BoxView HeightRequest="1" Color="#DDDDDD" Margin="0,10"/>

                        <!-- عنوان القائمة -->
                        <Label Text="الفروع الحالية"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#333333"
                               Margin="0,10,0,5"/>

                        <!-- رسالة "لا توجد فروع" -->
                        <Label x:Name="NoBranchesLabel"
                               Text="لا توجد فروع مضافة حتى الآن"
                               FontSize="14"
                               TextColor="#999999"
                               HorizontalOptions="Center"
                               Margin="0,20"
                               IsVisible="False"/>

                        <!-- قائمة الفروع -->
                        <CollectionView x:Name="BranchesList"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="15"
                                            Margin="0,8"
                                            BackgroundColor="#F5F5F5"
                                            Stroke="#DDDDDD"
                                            StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>

                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">

                                            <!-- معلومات الفرع -->
                                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                <Label Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="Black"/>
                                                <Label TextColor="#666666" FontSize="12">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="📍 المسافة: "/>
                                                            <Span Text="{Binding RadiusMeters}"/>
                                                            <Span Text=" متر"/>
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                                <Label TextColor="#666666" FontSize="12">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="📶 WiFi: "/>
                                                            <Span Text="{Binding CompanyWifiSSID}"/>
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </VerticalStackLayout>

                                            <!-- زر التعديل -->
                                            <buttons:SfButton Grid.Column="1"
                                                              Text="✏️"
                                                              Clicked="OnEditBranchClicked"
                                                              BindingContext="{Binding .}"
                                                              BackgroundColor="#2196F3"
                                                              TextColor="White"
                                                              CornerRadius="8"
                                                              WidthRequest="45"
                                                              HeightRequest="45"
                                                              FontSize="18"/>

                                            <!-- زر الحذف -->
                                            <buttons:SfButton Grid.Column="2"
                                                              Text="🗑️"
                                                              Clicked="OnDeleteBranchClicked"
                                                              BindingContext="{Binding .}"
                                                              BackgroundColor="#F44336"
                                                              TextColor="White"
                                                              CornerRadius="8"
                                                              WidthRequest="45"
                                                              HeightRequest="45"
                                                              FontSize="18"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- اللودر -->
        <core:SfBusyIndicator
            x:Name="Loader"
            Title="جارٍ العملية..."
            IsRunning="False"
            IsVisible="False"
            AnimationType="SingleCircle"
            IndicatorColor="#174DA1"
            BackgroundColor="#88000000"
            TextColor="#174DA1"/>
    </Grid>
</ContentPage>