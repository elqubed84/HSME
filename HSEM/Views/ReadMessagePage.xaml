<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="HSEM.Views.ReadMessagePage"
             Title="عرض الرسالة"
              xmlns:model="clr-namespace:HSEM.Models"
             NavigationPage.HasBackButton="False"
             BackgroundColor="#F8F8F8">
    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ToolbarItem_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.Arrow_forward}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem x:Name="menuu" Clicked="ToolbarItem_Clicked_1">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.More_vert}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid BackgroundColor="#1976D2" Padding="16">
            <Label Text="{Binding Message.Subject}" 
                   TextColor="White" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"/>
        </Grid>

        <ScrollView Grid.Row="1" Padding="16">
            <VerticalStackLayout Spacing="12">

                <!-- المرسل وتاريخ الإرسال -->
                <Frame BackgroundColor="White" Padding="12" CornerRadius="12" HasShadow="True">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="من:" FontAttributes="Bold" TextColor="Black"/>
                        <Label Text="{Binding Message.OtherParty.FullName}" TextColor="#1976D2"/>

                        <Label Text="تاريخ الإرسال:" FontAttributes="Bold" TextColor="Black"/>
                        <Label Text="{Binding Message.SentAt, StringFormat='{}{0:dd/MM/yyyy hh:mm tt}'}" TextColor="Black"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- الرسالة الأصلية (رد على رسالة) -->
                <Frame BackgroundColor="#F8F8F8" Padding="12" CornerRadius="10"
                       IsVisible="{Binding HasParentMessage}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="رد على رسالة:" FontAttributes="Bold" TextColor="Black"/>
                        <Label Text="{Binding ParentMessage.OtherParty.FullName}" TextColor="#1976D2"/>
                        <Label Text="{Binding ParentMessage.Subject}" FontAttributes="Bold" TextColor="Black"/>
                        <Label Text="{Binding ParentMessage.SentAt, StringFormat='تاريخ الإرسال: {0:dd/MM/yyyy hh:mm tt}'}"
                               FontSize="12" TextColor="Gray"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- نص الرسالة -->
                <Frame BackgroundColor="White" Padding="12" CornerRadius="12" HasShadow="True">
                    <Label Text="{Binding Message.Body}" 
                           LineBreakMode="WordWrap" TextColor="Black"
                           FontSize="16"/>
                </Frame>

                <!-- أزرار الرد والعودة -->
                <HorizontalStackLayout Spacing="12">
                    <Button Text="رد" 
                            IsVisible="{Binding CanReply}"
                            BackgroundColor="#1976D2"
                            TextColor="White"
                            CornerRadius="20"
                            Command="{Binding ReplyCommand}"/>
                    <Button Text="العودة" 
                            BackgroundColor="White"
                            TextColor="#1976D2"
                            BorderColor="#1976D2"
                            BorderWidth="1"
                            CornerRadius="20"
                            Command="{Binding BackCommand}"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Busy Indicator -->
        <core:SfBusyIndicator
            Title="جاري تحميل الرسالة..."
            FontAttributes="Bold"
            FontSize="20"
            AnimationType="SingleCircle"
            IndicatorColor="#174DA1"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Style="{StaticResource BlueGradientStyle}"
            TextColor="#174DA1" />
    </Grid>
</ContentPage>