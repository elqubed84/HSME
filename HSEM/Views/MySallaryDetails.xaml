<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:HSEM.Converters"
             x:Class="HSEM.Views.MySallaryDetails"
             BackgroundColor="{StaticResource PageBg}"
             FlowDirection="RightToLeft"
             Title="{Binding SelectedYearMonthText}">

    <ContentPage.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConverter" />
        <conv:TotalAfterAdditionsConverter x:Key="TotalAfterAdditionsConverter" />
        <conv:ListCountToBoolConverter x:Key="ListCountToBoolConverter" />
        <conv:ListCountToInverseBoolConverter x:Key="ListCountToInverseBoolConverter" />
    </ContentPage.Resources>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="0" Spacing="5">

                <!-- Card -->
                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout>

                        <!-- Header -->
                        <Border BackgroundColor="White" Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Grid BackgroundColor="{StaticResource PrimaryBlue}" Padding="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label Text="{Binding Payroll.EmployeeName, StringFormat='🧾 تفاصيل مرتب الموظف {0}'}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       FontSize="18" />
                            </Grid>
                        </Border>

                        <VerticalStackLayout Padding="14" Spacing="12">

                            <!-- بيانات الموظف -->
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="👤 البيانات" Style="{StaticResource SectionHeader}"/>
                                    <Label Text="{Binding Payroll.EmployeeName, StringFormat='الاسم: {0}'}"/>
                                    <Label Text="{Binding Payroll.DepartmentName, StringFormat='الإدارة: {0}'}"/>
                                    <Label Text="{Binding Payroll.MonthName, StringFormat='الشهر: {0}'}"/>
                                    <Label Text="{Binding Payroll.Year, StringFormat='السنة: {0}'}"/>
                                    <Label Text="{Binding Payroll.CreatedAt, StringFormat='تاريخ الإنشاء: {0:yyyy/MM/dd}'}"/>
                                </VerticalStackLayout>

                                <!-- تفاصيل المرتب الأساسي -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="💼 تفاصيل المرتب " Style="{StaticResource SectionHeader}"/>
                                    <Label Text="{Binding Payroll.BasicSalary, Converter={StaticResource CurrencyConverter}, StringFormat='الراتب المستحق: {0}'}"/>
                                    <Label Text="{Binding Payroll.AbsentDays, StringFormat='أيام الغياب: {0}'}"/>
                                    <Label Text="{Binding Payroll.AbsentDeduction, Converter={StaticResource CurrencyConverter}, StringFormat='قيمة خصم الغياب: {0}'}"/>
                                    <Label Text="{Binding Payroll.BaseAfterAbsence, Converter={StaticResource CurrencyConverter}, StringFormat='الراتب بعد خصم الغياب: {0}'}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#e6e6e6"/>

                            <!-- ✅ جديد - قسم البدلات -->
                            <VerticalStackLayout>
                                <Label Text="💰 البدلات" Style="{StaticResource SectionHeader}"/>

                                <CollectionView ItemsSource="{Binding Payroll.AllowancesList}"
                                                IsVisible="{Binding Payroll.AllowancesList.Count, Converter={StaticResource ListCountToBoolConverter}}">

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Frame Margin="0,4"
                                                   Padding="10"
                                                   BorderColor="#e0e0e0"
                                                   CornerRadius="8"
                                                   BackgroundColor="#f0f8ff">

                                                <VerticalStackLayout Spacing="6">

                                                    <!-- الصف الأول - اسم البدل والقيمة -->
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                                            <Label Text="📋"
                                                                   FontSize="14"/>
                                                            <Label Text="{Binding AllowanceTypeName}"
                                                                   FontSize="14"
                                                                   FontAttributes="Bold"/>
                                                            <Label Text="⭐"
                                                                   FontSize="12"
                                                                   IsVisible="{Binding IsCustom}"/>
                                                        </HorizontalStackLayout>

                                                        <Label Grid.Column="1"
                                                               Text="{Binding Amount, Converter={StaticResource CurrencyConverter}}"
                                                               FontSize="14"
                                                               FontAttributes="Bold"
                                                               TextColor="#2E7D32"
                                                               HorizontalTextAlignment="End"/>
                                                    </Grid>

                                                    <!-- الصف الثاني - نوع الحساب -->
                                                    <Grid ColumnDefinitions="Auto,*">
                                                        <Label Grid.Column="0"
                                                               Text="📊 نوع الحساب: "
                                                               FontSize="12"
                                                               TextColor="Gray"/>
                                                        <Label Grid.Column="1"
                                                               Text="{Binding CalculationType}"
                                                               FontSize="12"
                                                               TextColor="Gray"/>
                                                    </Grid>

                                                    <!-- الصف الثالث - التواريخ -->
                                                    <Grid ColumnDefinitions="*,*">
                                                        <Label Grid.Column="0"
                                                               Text="{Binding StartDate, StringFormat='📅 من: {0:yyyy/MM/dd}'}"
                                                               FontSize="12"
                                                               TextColor="Gray"/>

                                                        <Label Grid.Column="1"
                                                               FontSize="12"
                                                               TextColor="Gray"
                                                               HorizontalTextAlignment="Start">
                                                            <Label.FormattedText>
                                                                <FormattedString>
                                                                    <Span Text="📅 إلى: "/>
                                                                    <Span Text="{Binding EndDate, StringFormat='{0:yyyy/MM/dd}', FallbackValue='دائم'}"/>
                                                                </FormattedString>
                                                            </Label.FormattedText>
                                                        </Label>
                                                    </Grid>

                                                    <!-- الملاحظات (إن وجدت) -->
                                                    <Label Text="{Binding Notes, StringFormat='📝 {0}'}"
                                                           FontSize="11"
                                                           TextColor="Gray"
                                                           LineBreakMode="WordWrap"
                                                           IsVisible="{Binding Notes, Converter={StaticResource StringIsNotNullOrEmptyConverter}}"/>

                                                </VerticalStackLayout>

                                            </Frame>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                                <Label Text="لا توجد بدلات نشطة لهذا الموظف."
                                       IsVisible="{Binding Payroll.AllowancesList.Count, Converter={StaticResource ListCountToInverseBoolConverter}}"
                                       TextColor="Gray"
                                       Margin="0,8"/>

                                <!-- إجمالي البدلات -->
                                <Grid Padding="10" 
                                      BackgroundColor="#e8f5e9" 
                                      Margin="0,8,0,0"
                                      IsVisible="{Binding Payroll.AllowancesList.Count, Converter={StaticResource ListCountToBoolConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Label Text="إجمالي البدلات"
                                           Grid.Column="0"
                                           FontAttributes="Bold"
                                           TextColor="#2E7D32"/>

                                    <Label Text="{Binding TotalAllowances, Converter={StaticResource CurrencyConverter}}"
                                           Grid.Column="1"
                                           FontAttributes="Bold"
                                           TextColor="#2E7D32"/>
                                </Grid>

                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#e6e6e6"/>

                            <!-- الإضافات والخصومات -->
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="💰 المبالغ الإضافية" Style="{StaticResource SectionHeader}"/>
                                    <Label Text="{Binding Payroll.Allowances, Converter={StaticResource CurrencyConverter}, StringFormat='البدلات: {0}'}"/>
                                    <Label Text="{Binding Payroll.ExtraHoursAmount, Converter={StaticResource CurrencyConverter}, StringFormat='الإضافى: {0}'}"/>
                                    <Label Text="{Binding Payroll.Bonus, Converter={StaticResource CurrencyConverter}, StringFormat='المكافئات: {0}'}"/>
                                    <Label>
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <FormattedString.Spans>
                                                    <Span Text="الإجمالى: "/>
                                                    <Span Text="{Binding Path=Payroll, Converter={conv:TotalAfterAdditionsConverter}}" />
                                                </FormattedString.Spans>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="📉 جميع الإستقطاعات" Style="{StaticResource SectionHeader}"/>
                                    <Label Text="{Binding Payroll.Deductions, Converter={StaticResource CurrencyConverter}, StringFormat='الخصومات: {0}'}"/>
                                    <Label Text="{Binding Payroll.Loans, Converter={StaticResource CurrencyConverter}, StringFormat='السلف: {0}'}"/>
                                    <Label Text="{Binding Payroll.InsuranceEmployee, Converter={StaticResource CurrencyConverter}, StringFormat='تأميناتك: {0}'}"/>
                                    <Label Text="{Binding Payroll.IncomeTax, Converter={StaticResource CurrencyConverter}, StringFormat='الضريبة: {0}'}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#e6e6e6"/>

                            <!-- السلف -->
                            <VerticalStackLayout>
                                <Label Text="💳 بيانات السلف" Style="{StaticResource SectionHeader}"/>

                                <CollectionView ItemsSource="{Binding Payroll.LoansList}"
                                                IsVisible="{Binding Payroll.LoansList.Count, Converter={StaticResource ListCountToBoolConverter}}">

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Frame Margin="0,4"
                                                   Padding="10"
                                                   BorderColor="#e0e0e0"
                                                   CornerRadius="8"
                                                   BackgroundColor="#fafafa">

                                                <VerticalStackLayout Spacing="6">

                                                    <!-- الصف الأول -->
                                                    <Grid ColumnDefinitions="*,*">
                                                        <Label Grid.Column="0"
                                                               FontSize="13"
                                                               Text="{Binding Date, StringFormat='📅 التاريخ: {0:yyyy/MM/dd}'}"/>

                                                        <Label Grid.Column="1"
                                                               FontSize="13"
                                                               HorizontalTextAlignment="Start"
                                                               Text="{Binding Amount, Converter={StaticResource CurrencyConverter}, StringFormat='💰 المبلغ: {0}'}"/>
                                                    </Grid>

                                                    <!-- الصف الثاني -->
                                                    <Grid ColumnDefinitions="*,*">
                                                        <Label Grid.Column="0"
                                                               FontSize="13"
                                                               Text="{Binding Installments, StringFormat='📊 عدد الأقساط: {0}'}"/>

                                                        <Label Grid.Column="1"
                                                               FontSize="13"
                                                               HorizontalTextAlignment="Start"
                                                               Text="{Binding PaidInstallments, StringFormat='✅ عدد الأقساط المدفوعة: {0}'}"/>
                                                    </Grid>

                                                    <!-- الصف الثالث -->
                                                    <Grid ColumnDefinitions="*,*">
                                                        <Label Grid.Column="0"
                                                               FontSize="13"
                                                               Text="{Binding RemainingInstallments, StringFormat='📆 الأقساط المتبقية: {0}'}"/>

                                                        <Label Grid.Column="1"
                                                               FontSize="13"
                                                               HorizontalTextAlignment="Start"
                                                               Text="{Binding Remaining, Converter={StaticResource CurrencyConverter}, StringFormat='💸  المتبقي: {0}'}"/>
                                                    </Grid>

                                                </VerticalStackLayout>

                                            </Frame>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                                <Label Text="لا توجد سلف حالية لهذا الموظف."
                                       IsVisible="{Binding Payroll.LoansList.Count, Converter={StaticResource ListCountToInverseBoolConverter}}"
                                       TextColor="Gray"/>

                                <!-- إجمالي المتبقي -->
                                <Grid Padding="10" BackgroundColor="#e9f3ff" Margin="0,8,0,0"
                                      IsVisible="{Binding Payroll.LoansList.Count, Converter={StaticResource ListCountToBoolConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Label Text="إجمالي المتبقي من جميع السلف"
                                           Grid.Column="0"
                                           FontAttributes="Bold"/>

                                    <Label Text="{Binding TotalRemaining, Converter={StaticResource CurrencyConverter}}"
                                           Grid.Column="1"
                                           FontAttributes="Bold"/>
                                </Grid>

                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#e6e6e6"/>

                            <!-- جدول الجزاءات -->
                            <VerticalStackLayout>
                                <Label Text="⚠️ الجزاءات" Style="{StaticResource SectionHeader}" />

                                <CollectionView ItemsSource="{Binding Payroll.PenaltiesList}"
                                                IsVisible="{Binding Payroll.PenaltiesList.Count, Converter={StaticResource ListCountToBoolConverter}}">

                                    <!-- Header -->
                                    <CollectionView.Header>
                                        <Grid ColumnDefinitions="*,*,*,*" Padding="8" BackgroundColor="#f8f9fa">

                                            <Label Text="📅 التاريخ"
                                                   Grid.Column="0"
                                                   HorizontalTextAlignment="Start"/>

                                            <Label Text="💰 المبلغ"
                                                   Grid.Column="1"
                                                   HorizontalTextAlignment="Center"/>

                                            <Label Text="📝 السبب"
                                                   Grid.Column="2"
                                                   Grid.ColumnSpan="2"
                                                   HorizontalTextAlignment="Center"/>

                                        </Grid>
                                    </CollectionView.Header>

                                    <!-- Items -->
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,*,*,*" Padding="8">

                                                <!-- التاريخ -->
                                                <Label Text="{Binding Date, StringFormat='{0:yyyy/MM/dd}'}"
                                                       Grid.Column="0"
                                                       HorizontalTextAlignment="Start"/>

                                                <!-- المبلغ -->
                                                <Label Text="{Binding DeductionValue, Converter={StaticResource CurrencyConverter}}"
                                                       Grid.Column="1"
                                                       HorizontalTextAlignment="Center"
                                                       FontAttributes="Bold"/>

                                                <!-- السبب -->
                                                <Label Text="{Binding Description}"
                                                       Grid.Column="2"
                                                       Grid.ColumnSpan="2"
                                                       HorizontalTextAlignment="Center"
                                                       LineBreakMode="WordWrap"/>

                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                                <Label Text="لا توجد جزاءات لهذا الشهر."
                                       IsVisible="{Binding Payroll.PenaltiesList.Count, Converter={StaticResource ListCountToInverseBoolConverter}}"
                                       TextColor="Gray"/>

                                <!-- إجمالي الجزاءات -->
                                <Grid Padding="10"
                                      BackgroundColor="#fff3cd"
                                      Margin="0,8,0,0"
                                      IsVisible="{Binding Payroll.PenaltiesList.Count, Converter={StaticResource ListCountToBoolConverter}}">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Label Text="إجمالي الجزاءات"
                                           Grid.Column="0"
                                           FontAttributes="Bold"/>

                                    <Label Text="{Binding TotalPenalties, Converter={StaticResource CurrencyConverter}}"
                                           Grid.Column="1"
                                           FontAttributes="Bold"/>
                                </Grid>

                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#e6e6e6"/>

                            <!-- مساهمة الشركة -->
                            <VerticalStackLayout>
                                <Label Text="🏢 مساهمة الشركة" Style="{StaticResource SectionHeader}"/>
                                <Label Text="{Binding Payroll.InsuranceCompany, Converter={StaticResource CurrencyConverter}, StringFormat='تأمينات الشركة: {0}'}"/>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#e6e6e6"/>

                            <!-- صافي المرتب -->
                            <VerticalStackLayout HorizontalOptions="Center" Padding="10" BackgroundColor="#e8f5e9">
                                <Label Text="{Binding Payroll.NetSalary, Converter={StaticResource CurrencyConverter}, StringFormat='💵 صافي المرتب: {0}'}"
                                       FontSize="20" FontAttributes="Bold" TextColor="#2E7D32"/>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
