<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HSEM.Views.MyPermissions"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             xmlns:model="clr-namespace:HSEM.Models"
             xmlns:vm="clr-namespace:HSEM.ViewModels"
             
             Title="طلبات الإذن"
              NavigationPage.HasBackButton="False"
             BackgroundColor="#F8F8F8">
    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ToolbarItem_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1"  FontFamily="Icon" Glyph="{x:Static model:IconFont.Arrow_forward}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem x:Name="menuu" Clicked="ToolbarItem_Clicked_1">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.More_vert}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <ContentPage.BindingContext>
        <vm:MyPermissionsViewModel />
    </ContentPage.BindingContext>
    <ContentPage.Resources>
        <ResourceDictionary>
            <vm:LeaveStatusToColorConverter x:Key="LeaveStatusToColorConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>


    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="15" Spacing="15">

                <Label Text="طلبات الإذن"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#1976D2"/>

                <CollectionView ItemsSource="{Binding MyRequests}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="White"
                    Padding="12"
                    Margin="0,0,0,10">

                                <VerticalStackLayout Spacing="10">

                                    <!-- تاريخ الطلب في المنتصف -->
                                    <Label Text="{Binding DateText}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="DarkGray"/>

                                    <!-- نوع الطلب و TypeText -->
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*">
                                        <Label Text="نوع الطلب:" FontSize="12" TextColor="Gray"/>
                                        <Label Text="{Binding TypeText}" FontSize="14" TextColor="Black"  Grid.Row="1"/>
                                        <Label Text="الحالة:" FontSize="12" TextColor="Gray" Grid.Column="1" HorizontalOptions="End"/>
                                        <Label Text="{Binding StatusText}"  FontSize="14"
 TextColor="{Binding Status, Converter={StaticResource LeaveStatusToColorConverter}}"  HorizontalOptions="End" Grid.Row="1" Grid.Column="1" />
                                    </Grid>

                                    <!-- حالة الطلب و StatusText -->
                                    <!--<Grid ColumnDefinitions="*,*">
                                        <Label Text="الحالة:" FontSize="12" TextColor="Gray"/>
                                        <Label Text="{Binding StatusText}"  HorizontalOptions="End" Grid.Column="1"
                               FontSize="14"
                               TextColor="{Binding Status, Converter={StaticResource LeaveStatusToColorConverter}}"/>
                                    </Grid>-->

                                    <!-- تفاصيل الوقت والنطاق -->
                                    <Grid ColumnDefinitions="1*,1*" RowDefinitions="Auto,Auto">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="نطاق الإذن:" FontSize="12" TextColor="Gray"/>
                                            <Label Text="{Binding ScopeText}" FontSize="14" TextColor="Black"/>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="عدد الساعات:" FontSize="12" TextColor="Gray" VerticalOptions="End" HorizontalOptions="End"/>
                                            <Label Text="{Binding RequestedHours}" FontSize="14" TextColor="Black" VerticalOptions="End" HorizontalOptions="End"/>
                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- شريط صغير أسفل البطاقة -->
                                    <BoxView HeightRequest="2" BackgroundColor="#E0E0E0" Margin="0,8,0,0"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- مؤشر التحميل -->
        <core:SfBusyIndicator IsVisible="{Binding IsBusy}" 
                              IsRunning="{Binding IsBusy}" 
                              Title="جارٍ التحميل..."  IndicatorColor="#174DA1" TextColor="#174DA1"
                              BackgroundColor="#88000000"/>
    </Grid>
</ContentPage>
