<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HSEM.Views.EmployeeEvaluationDetailsPage"
             xmlns:local="clr-namespace:HSEM.Converters"
             xmlns:vm="clr-namespace:HSEM.ViewModels"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
              xmlns:model="clr-namespace:HSEM.Models"
             BackgroundColor="#F8F8F8"
             NavigationPage.HasBackButton="False"
             Title="تفاصيل التقييم">
    <ContentPage.ToolbarItems>

        <ToolbarItem Clicked="ToolbarItem_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1"  FontFamily="Icon" Glyph="{x:Static model:IconFont.Arrow_forward}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem x:Name="menuu" Clicked="ToolbarItem_Clicked_1">
            <ToolbarItem.IconImageSource>
                <FontImageSource Color="#174da1" FontFamily="Icon" Glyph="{x:Static model:IconFont.More_vert}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    <ContentPage.Resources>
        <ResourceDictionary>
            <local:StarColorConverter x:Key="StarColorConverter" />
            <local:ScoreToPercentageConverter x:Key="ScoreToPercentageConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView>

            <VerticalStackLayout Padding="20" Spacing="12">

                <!-- التقييم النهائي -->
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="2">
                        <Label Text="★" FontSize="32" TextColor="{Binding AverageScore, Converter={StaticResource StarColorConverter}, ConverterParameter=1}"/>
                        <Label Text="★" FontSize="32" TextColor="{Binding AverageScore, Converter={StaticResource StarColorConverter}, ConverterParameter=2}"/>
                        <Label Text="★" FontSize="32" TextColor="{Binding AverageScore, Converter={StaticResource StarColorConverter}, ConverterParameter=3}"/>
                        <Label Text="★" FontSize="32" TextColor="{Binding AverageScore, Converter={StaticResource StarColorConverter}, ConverterParameter=4}"/>
                        <Label Text="★" FontSize="32" TextColor="{Binding AverageScore, Converter={StaticResource StarColorConverter}, ConverterParameter=5}"/>
                    </HorizontalStackLayout>

                    <Label Text="{Binding AverageScore, Converter={StaticResource ScoreToPercentageConverter}}" 
                      FontSize="25" TextColor="Black" FontAttributes="Bold" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- الملاحظات -->
                <Label Text="{Binding Notes}" FontSize="16" TextColor="DarkGreen" LineBreakMode="WordWrap"/>

                <!-- تفاصيل البنود -->
                <CollectionView ItemsSource="{Binding Items}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" Margin="0,6" BackgroundColor="White" StrokeShape="RoundRectangle 16" Shadow="0,2,10,#33000000">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding CriteriaName}" TextColor="Black" FontAttributes="Bold" FontSize="20"/>
                                    <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                        <!-- نجوم لكل بند -->
                                        <Label Text="★" FontSize="24" TextColor="{Binding Score, Converter={StaticResource StarColorConverter}, ConverterParameter=1}"/>
                                        <Label Text="★" FontSize="24" TextColor="{Binding Score, Converter={StaticResource StarColorConverter}, ConverterParameter=2}"/>
                                        <Label Text="★" FontSize="24" TextColor="{Binding Score, Converter={StaticResource StarColorConverter}, ConverterParameter=3}"/>
                                        <Label Text="★" FontSize="24" TextColor="{Binding Score, Converter={StaticResource StarColorConverter}, ConverterParameter=4}"/>
                                        <Label Text="★" FontSize="24" TextColor="{Binding Score, Converter={StaticResource StarColorConverter}, ConverterParameter=5}"/>
                                        <Label Text="{Binding Score}" FontSize="16"/>
                                        <Label Text="/" FontSize="16"/>
                                        <Label Text="{Binding MaxScore}" FontSize="16"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>


        </ScrollView>
        <core:SfBusyIndicator
x:Name="lOADER"
Title="برجاء الإنتظار..."
   FontAttributes="Bold"
   FontSize="25"
AnimationType="SingleCircle"
IndicatorColor="#174DA1"
IsRunning="{Binding IsBusy}"
IsVisible="{Binding IsBusy}"
Style="{StaticResource BlueGradientStyle}"
TextColor="#174DA1" />
    </Grid>
</ContentPage>
