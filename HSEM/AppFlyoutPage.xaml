<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage
    x:Class="HSEM.AppFlyoutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:HSEM"
    xmlns:views="clr-namespace:HSEM.Views"
    xmlns:vm="clr-namespace:HSEM.ViewModels"
    BackgroundColor="#5C000000"
    FlyoutLayoutBehavior="Default">
    <FlyoutPage.BindingContext>
        <vm:BaseViewModel/>
    </FlyoutPage.BindingContext>
    <FlyoutPage.Flyout>
        <pages:AppFlyoutPageFlyout x:Name="FlyoutPage" />
    </FlyoutPage.Flyout>
    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <views:LoginPage />
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>

</FlyoutPage>