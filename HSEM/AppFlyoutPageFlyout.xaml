<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HSEM.AppFlyoutPageFlyout"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HSEM.Views"
    Title="AppFlyoutPageFlyout"
    BackgroundColor="#5C000000"
    BackgroundImageSource="photo.jpg">
    <StackLayout>
        <ListView x:Name="MenuItemsListView"
          ItemsSource="{Binding MenuGroups}"
          IsGroupingEnabled="True"
          HasUnevenRows="True"
          SeparatorVisibility="None"
          BackgroundColor="Transparent">
            <ListView.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" HeightRequest="150">
                        <local:Header />
                    </Grid>
                    <Grid Grid.Row="1" HeightRequest="150">
                        <Label Text="" TextColor="Black" />
                    </Grid>
                </Grid>
            </ListView.Header>
            <ListView.GroupHeaderTemplate>
                <DataTemplate>
                    <ViewCell IsEnabled="False" Height="32">
                        <StackLayout Orientation="Horizontal"
                             Padding="16,10,16,4"
                             Spacing="8">
                            <Label Text="{Binding GroupName}"
                           TextColor="#8899bb"
                           FontFamily="Montserrat-SemiBold"
                           FontSize="10"/>
                            <BoxView HeightRequest="1"
                             BackgroundColor="#8899bb"
                             Opacity="0.2"
                             HorizontalOptions="FillAndExpand"
                             VerticalOptions="Center"/>
                        </StackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.GroupHeaderTemplate>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid Padding="10,2">
                            <StackLayout Orientation="Horizontal"
                                 Padding="12,10"
                                 Spacing="14">
                                <Image Source="{Binding Icon}"
                               WidthRequest="20" HeightRequest="20"
                               VerticalOptions="Center"/>
                                <Label Text="{Binding Title}"
                               TextColor="White"
                               FontFamily="Montserrat-Medium"
                               FontSize="14"
                               VerticalOptions="Center"/>
                            </StackLayout>
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
